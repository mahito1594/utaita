{
  "name": "utaita",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare": "panda codegen",
    "api:spec": "node --env-file=.env.local scripts/fetch-openapi.mjs",
    "api:types": "openapi-typescript openapi.json -o src/api/schema.d.ts",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check",
    "check:fix": "biome check --write",
    "check:fix:unsafe": "biome check --write --unsafe",
    "check:deps": "depcruise src",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "blurhash": "^2.0.5",
    "dompurify": "^3.4.12",
    "lucide-solid": "^1.24.0",
    "openapi-fetch": "^0.17.0",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@pandacss/dev": "^1.11.4",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "dependency-cruiser": "^18.0.0",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
