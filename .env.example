# Copy to .env.local (untracked) and fill in your dev instance.
# Neither variable is VITE_-prefixed: they are read server-side only
# (vite.config.ts via loadEnv, scripts/fetch-openapi.mjs) and must never
# reach the client bundle — see ADR-0006.

# Akkoma instance the dev proxy and spec fetching target.
DEV_INSTANCE_URL=https://your.instance.example

# Optional: manually issued access token. When set, the Vite dev proxy
# injects it as an Authorization header server-side. Leave unset to
# exercise the 401 path.
DEV_ACCESS_TOKEN=
